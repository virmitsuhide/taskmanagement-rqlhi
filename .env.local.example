# ─── Supabase ─────────────────────────────────────────────────────────────────
# Dashboard Supabase > Settings > API

# Server-only (tidak boleh bocor ke browser)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Public (aman untuk browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Database (Drizzle ORM) ────────────────────────────────────────────────────
# Dashboard Supabase > Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxxx.supabase.co:5432/postgres

# ─── Session ──────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=ganti_dengan_string_panjang_acak_minimal_32_karakter

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Dashboard Resend > API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=no-reply@rqlhi.com

# ─── App ──────────────────────────────────────────────────────────────────────
# URL deployment Vercel (tanpa trailing slash)
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app
