# Supabase — dari dashboard Supabase > Settings > API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Session secret — minimal 32 karakter acak, generate dengan:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=ganti_dengan_string_panjang_acak_minimal_32_karakter

# Resend — dari dashboard Resend > API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=no-reply@rqlhi.com
